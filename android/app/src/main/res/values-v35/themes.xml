<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      On Android 15+ (API 35) edge-to-edge is enforced for apps targeting SDK 35,
      which draws activity content behind the system/app bars. We opt out so the
      framework keeps insetting content below the status bar and ActionBar.
    -->
    <style name="Theme.TaskViewer" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>
</resources>
